# Supabase (Dashboard > Project Settings > API Keys / Connect)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3003
NEXT_PUBLIC_DEV_AUTH_BYPASS=false

# New projects: prefer the publishable key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# Legacy projects: the anon key also works. Leave this empty if using publishable key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Appearance AI server. No NEXT_PUBLIC prefix because this is server-side only.
AI_SERVER_URL=http://localhost:8001

# Payment provider.
# Use mock for local UI review. Use toss only with Toss sandbox keys.
NEXT_PUBLIC_PAYMENT_PROVIDER=mock
PAYMENT_PROVIDER=mock

# Toss Payments sandbox.
# NEXT_PUBLIC_TOSS_CLIENT_KEY is safe for the browser. TOSS_SECRET_KEY is server-only.
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# Server-only keys. Never expose these with NEXT_PUBLIC_.
# PAYMENT_INTERNAL_SECRET protects internal refund/cancel calls.
# SUPABASE_SERVICE_ROLE_KEY lets server routes reconcile payment/refund state.
PAYMENT_INTERNAL_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
