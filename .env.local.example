# Supabase (Dashboard > Project Settings > API Keys / Connect)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3003
NEXT_PUBLIC_DEV_AUTH_BYPASS=false

# New projects: prefer the publishable key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# Legacy projects: the anon key also works. Leave this empty if using publishable key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Appearance AI server. No NEXT_PUBLIC prefix because this is server-side only.
AI_SERVER_URL=http://localhost:8001
