# Supabase 연결 (service_role 키 — 절대 클라이언트에 노출 금지)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# AI 모델 가중치 파일 경로 (없으면 ImageNet pretrained backbone 사용)
MODEL_WEIGHTS_PATH=./weights/resnet50_scut.pth

# 서버 포트
PORT=8001

# CORS 허용 오리진 (쉼표로 구분)
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# 이미지 다운로드 타임아웃 (초, 기본: 15)
IMAGE_DOWNLOAD_TIMEOUT=15

# 이미지 최대 용량 (바이트, 기본: 20MB = 20971520)
MAX_IMAGE_BYTES=20971520
